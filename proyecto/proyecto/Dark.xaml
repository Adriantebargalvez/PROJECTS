<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="exempleTemes.Resources.Dark">

    <!-- Colores del tema oscuro -->
    <Color x:Key="PageBackgroundColor">Black</Color>
    <Color x:Key="NavigationBarColor">Teal</Color>
    <Color x:Key="PrimaryColor">Teal</Color>
    <Color x:Key="SecondaryColor">White</Color>
    <Color x:Key="PrimaryTextColor">White</Color>
    <Color x:Key="SecondaryTextColor">#D3D3D3</Color>
    <Color x:Key="TertiaryTextColor">#A9A9A9</Color>
    <Color x:Key="ButtonBackgroundColor">#005F73</Color>
    <Color x:Key="ButtonTextColor">White</Color>
    <Color x:Key="BorderColor">#444444</Color>

    <!-- Ajuste del color del fondo y texto de Entry -->
    <Color x:Key="EntryTextColor">White</Color>
    <!-- Blanco para ser legible -->
    <Color x:Key="EntryBackgroundColor">#1C1C1C</Color>
    <!-- Fondo oscuro -->
</ResourceDictionary>
