<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="proyecto.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:proyecto"
    Shell.FlyoutBehavior="Disabled"
    Title="proyecto">
    <!-- Página de inicio de sesión, que será la primera página que se carga -->
    <ShellContent
Title="Inicio de Sesión"
ContentTemplate="{DataTemplate local:inicio}"
Route="Inicio" />
    <ShellContent
Title="Inicio de Sesión"
ContentTemplate="{DataTemplate local:EmpresasContactadas}"
Route="EmpresasContactadas" />


    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
